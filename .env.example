# Copy this file to .env.local and fill in the values for your own CAD reader service.

# Default policy: DWG reading through a remote BricsCAD-compatible service.
CADLIST_DWG_READER_PRIORITY=remote-bricscad

# Required unless another integration supplies the endpoint at runtime.
CADLIST_REMOTE_BRICSCAD_URL=
CADLIST_REMOTE_BRICSCAD_TOKEN=
CADLIST_REMOTE_BRICSCAD_TIMEOUT=900

# Optional Tianzheng/T20 Windows CAD worker. Leave blank unless deployed.
CADLIST_TANGENT_WORKER_URL=
CADLIST_TANGENT_WORKER_TOKEN=
CADLIST_TANGENT_WORKER_TIMEOUT=900

# Optional when running scripts/remote_bricscad_server.py yourself.
# Defaults bind to localhost. A token is required for non-loopback hosts.
BRICSCAD_SERVER_HOST=127.0.0.1
BRICSCAD_SERVER_PORT=8765
BRICSCAD_SERVER_TOKEN=
BRICSCAD_MAX_UPLOAD_MB=100
BRICSCAD_MAX_ENTITY_LIMIT=100000
BRICSCAD_MAX_CONCURRENT=2
